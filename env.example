# Copy to .env — never commit real keys.
# Get a key: https://scripture.api.bible/signup
SCRIPTURE_API_KEY=

# Public site URL for share previews (Open Graph / iMessage). No trailing slash.
# Example GitHub Pages: https://yourusername.github.io/verseway
# VITE_SITE_URL=

# Optional: put key in the client bundle (public) and call API.Bible directly instead of /scripture-api proxy.
# VITE_SCRIPTURE_API_KEY=
